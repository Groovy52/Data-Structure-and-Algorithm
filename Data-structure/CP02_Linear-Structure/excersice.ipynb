   "source": [
    "import sys\n",
    "sys.setrecursionlimit(10**6)\n",
    "\n",
    "def solution(A, B):\n",
    "    while A != 0 and A%10!=1:\n",
    "        if (A%10)!= 0 or B==1:\n",
    "            print(A%10, end='')\n",
    "            B = 1\n",
    "        \n",
    "        solution(A//10, B)\n",
    "\n",
    "solution(123456789, 0)"
   ]
