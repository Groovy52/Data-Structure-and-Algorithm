     ]
    }
   ],
   "source": [
    "A.sort(reverse=True)\n",
    "\n",
    "count = 0\n",
    "\n",
    "for coin in A:\n",
    "    count += K // coin \n",
    "    K %= coin \n",
    "    print(count, K)"
   ]
